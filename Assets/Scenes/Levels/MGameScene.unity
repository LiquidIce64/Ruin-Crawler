  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0f99ae107e8cc4444bfee0cd31b2e124, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialManager
  tutorialPanel: {fileID: 1479068769}
  messageText: {fileID: 931856330}
  keyImage: {fileID: 467459371}
  canvasGroup: {fileID: 1479068773}
  fadeInDuration: 1
  fadeOutDuration: 2
  steps:
  - stepId: move_forward
    message: "\u041D\u0430\u0436\u043C\u0438 W/S, \u0447\u0442\u043E\u0431\u044B
      \u0435\u0445\u0430\u0442\u044C \u0432\u043F\u0435\u0440\u0451\u0434/\u043D\u0430\u0437\u0430\u0434"
    keyIcon: {fileID: 0}
    isCompleted: 0
  - stepId: steer
    message: "\u041D\u0430\u0436\u043C\u0438 A/D, \u0447\u0442\u043E\u0431\u044B
      \u043F\u043E\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0442\u044C \u043A\u043E\u043B\u0451\u0441\u0430"
    keyIcon: {fileID: 0}
    isCompleted: 0
  - stepId: turbo
    message: "\u0423\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439 Shift \u0434\u043B\u044F
      \u0442\u0443\u0440\u0431\u043E-\u0443\u0441\u043A\u043E\u0440\u0435\u043D\u0438\u044F"
    keyIcon: {fileID: 0}
    isCompleted: 0
  - stepId: jump
    message: "\u041D\u0430\u0436\u043C\u0438 Space, \u0447\u0442\u043E\u0431\u044B
      \u043F\u0440\u044B\u0433\u043D\u0443\u0442\u044C"
    keyIcon: {fileID: 0}
    isCompleted: 0
  - stepId: attach_winch
    message: "\u041D\u0430\u0436\u043C\u0438 Q \u0438\u043B\u0438 E, \u0447\u0442\u043E\u0431\u044B
      \u0437\u0430\u0446\u0435\u043F\u0438\u0442\u044C \u043B\u0435\u0431\u0451\u0434\u043A\u0443
      \u0437\u0430 \u0442\u043E\u0447\u043A\u0443"
    keyIcon: {fileID: 0}
    isCompleted: 0
  - stepId: swing_winch
    message: "\u0423\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439 W, A, S, D,
      \u0447\u0442\u043E\u0431\u044B \u0440\u0430\u0441\u043A\u0430\u0447\u0438\u0432\u0430\u0442\u044C\u0441\u044F
      \u043D\u0430 \u043B\u0435\u0431\u0435\u0434\u043A\u0435"
    keyIcon: {fileID: 0}
    isCompleted: 0
  - stepId: pull_winch
    message: "\u0423\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439 Q \u0438\u043B\u0438
      E, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0434\u0442\u044F\u043D\u0443\u0442\u044C
      \u043B\u0435\u0431\u0451\u0434\u043A\u0443"
    keyIcon: {fileID: 0}
    isCompleted: 0
  - stepId: loose_winch
    message: "\u0423\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0439 Ctrl+Q \u0438\u043B\u0438
      Ctrl+E, \u0447\u0442\u043E\u0431\u044B \u043E\u0441\u043B\u0430\u0431\u0438\u0442\u044C
      \u043B\u0435\u0431\u0451\u0434\u043A\u0443"
    keyIcon: {fileID: 0}
    isCompleted: 0
  - stepId: attach_movable
    message: "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439 \u043B\u0435\u0431\u0451\u0434\u043A\u0443,
      \u0447\u0442\u043E\u0431\u044B \u0440\u0430\u0441\u0447\u0438\u0441\u0442\u0438\u0442\u044C
      \u043F\u0443\u0442\u044C"
    keyIcon: {fileID: 0}
    isCompleted: 0
  playerController: {fileID: 1107279308}
  vehicleController: {fileID: 523846180}
